{
  "name": "playground",
  "version": "0.0.1",
  "private": true,
  "description": "Playground for testing nest-swaggify",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "swagger": "pnpm build && generate-swagger",
    "swagger:all": "pnpm build && generate-swagger --group=all",
    "swagger:public": "pnpm build && generate-swagger --group=public-api",
    "swagger:internal": "pnpm build && generate-swagger --group=internal-api"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "nest-swaggify": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
